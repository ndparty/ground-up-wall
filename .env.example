DATABASE_URL=postgres://localhost:5432/ground_up_wall_dev
DATABASE_URL_TEST=postgres://localhost:5432/ground_up_wall_test
STORAGE_PATH=./uploads
REALTIME_PROVIDER=memory
# Production (VPS / HTTPS): set DEPLOYED=1 for HSTS, Secure cookies, and required seed passwords.
DEPLOYED=
HOSTNAME=127.0.0.1
PORT=8080
# Required in deployed environments. Local dev falls back to admin123 if unset.
ADMIN_INITIAL_PASSWORD=
# Demo accounts (seed.ts). Local dev falls back to demo123 if unset.
DEMO_MODERATOR_PASSWORD=
DEMO_DISPLAY_PASSWORD=

{
  "nodeModulesDir": "manual",
  "tasks": {
    "start": "deno run -A --watch=static/,routes/,lib/,islands/,components/ dev.ts",
    "dev": "deno run -A --watch=static/,routes/,lib/,islands/,components/ dev.ts",
    "build": "deno run -A dev.ts build",
    "test": "deno test -P",
    "test:unit": "deno test -P --ignore=tests/e2e/",
    "test:e2e": "deno test -P tests/e2e/",
    "test:e2e:smoke": "deno test -P tests/e2e/ --filter=smoke",
    "db:migrate": "deno run -A scripts/migrate.ts",
    "db:seed": "deno run -A scripts/seed.ts",
    "check": "deno fmt --check . && deno lint . && deno check main.ts"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ]
  },
  "imports": {
    "@/": "./",
    "$fresh/": "jsr:@fresh/core@^2.3.3/",
    "$fresh/dev": "jsr:@fresh/core@^2.3.3/dev",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "fresh/dev": "jsr:@fresh/core@^2.3.3/dev",
    "preact": "npm:preact@^10.29.2",
    "preact/": "npm:preact@^10.29.2/",
    "preact/jsx-runtime": "npm:preact@^10.29.2/jsx-runtime",
    "preact-render-to-string": "npm:preact-render-to-string@^6.6.7",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@preact/signals-core": "npm:@preact/signals-core@^1.8.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/fs": "jsr:@std/fs@^1.0.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@std/encoding": "jsr:@std/encoding@^1.0.0",
    "@db/postgres": "jsr:@db/postgres@^0.19.5",
    "bcrypt": "jsr:@felix/bcrypt@^1.0.8"
  },
  "lint": {
    "rules": {
      "exclude": ["no-empty"],
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100
  },
  "test": {
    "permissions": {
      "read": true,
      "write": true,
      "net": true,
      "env": true,
      "run": true,
      "ffi": true
    }
  },
  "exclude": ["**/_fresh/*"]
}
